# ============================================
# Usage Instructions:
# 1. Copy this file as .env
# 2. Fill in OPENAI_API_KEY and LANGSMITH_API_KEY
# 3. Fill in HOST_IP
# 4. Optionally fill in TAVILY_SEARCH_KEY to enable search
# 5. Adjust feature switches as needed (USE_PPT/USE_EXCEL)
# 6. Save the file and start the application
# ============================================

# ============================================
# API Key Configuration - Required authentication information for project operation
# ============================================
# SiliconFlow API Key (Required)
# Purpose: Used to access SiliconFlow's AI model services
# Free quota available at: https://cloud.siliconflow.cn/i/FVis58aF
# Note: You can view the API key in the console after registration
OPENAI_API_KEY=

# LangSmith API Key (Required)
# Purpose: Used for LangChain tracing and monitoring functionality
# Free registration at: https://www.langsmith.com/
# Note: You can generate an API key in the settings page after registration
LANGSMITH_API_KEY=

# LangChain Project Name
# Purpose: Organize and categorize your tracing data in LangSmith
# Description: All trace records will be grouped under this project for easy management of multiple applications
LANGCHAIN_PROJECT="all_agent"

# Enable LangChain Tracing (Version 2)
# Purpose: Automatically trace all LLM calls and chain executions in LangChain applications
# Description: When set to true, all LangChain operations will be sent to the LangSmith platform
# Tip: Set to true for debugging, can be disabled in production to reduce overhead
LANGCHAIN_TRACING_V2=true

# Tavily Search API Key (Optional)
# Purpose: If set, enables internet search functionality
# Free registration at: https://tavily.com/
# Note: If not set, internet search is disabled and only local knowledge is used
TAVILY_SEARCH_KEY=

# ============================================
# Server Network Configuration
# ============================================
# Host IP Address - Network interface IP bound to the server (Required)
# Purpose:
# 1. When the Agent creates files, MINIO generates a download link for users to download files. This download link starts with HOST_IP.
# 2. The frontend program accesses the backend program via the HOST_IP path.
# Note: Requires an externally accessible IP address or domain name. If there is no public network interface, fill in the local intranet IP. Do not fill in localhost or 127.0.0.1
HOST_IP =

# MinIO Object Storage Service Port - Used for file storage and access
MINIO_PORT = 9900

# MinIO Console Port - Used for accessing the MinIO management interface
MINIO_CONSOLE_PORT = 9901

# MinIO Access Key - Username for API authentication
MINIO_ACCESS_KEY=minioadmin

# MinIO Secret Key - Password for API authentication
MINIO_SECRET_KEY=minioadmin

# Agent Frontend Interface Port - Web user interface access port
AGENT_UI_PORT=3000

# Agent Backend Service Port - API service access port
AGENT_SERVER_PORT=8000

# ============================================
# Application Feature Configuration - Controls switches for various project features
# ============================================
# Allow blocking loops in background jobs
# Description: Keep this fixed value to implement isolated loops and avoid task interference
# Options: true/false
BG_JOB_ISOLATED_LOOPS=true

# Enable PowerPoint creation feature
# Description: When set to true, AI can create and edit PPT documents
# Options: true/false
USE_PPT=true

# Enable Excel creation feature
# Description: When set to true, AI can create and edit Excel spreadsheets
# Options: true/false
USE_EXCEL=true

# ============================================
# Model Configuration - AI model selection and parameter settings
# ============================================
# Base Large Language Model (LLM)
# Description: Main model used for text generation and conversation
BASE_LLM=Qwen/Qwen3.5-122B-A10B

# Base Vision Language Model (VLM)
# Description: Used for image understanding and multimodal tasks
BASE_VLM=Qwen/Qwen3-VL-30B-A3B-Instruct

# Image Generation Model
# Description: Used to generate images based on text descriptions
IMAGE_MODEL=Qwen/Qwen-Image

# Image Editing Model
# Description: Used to modify and edit existing images
EDIT_IMAGE_MODEL=Qwen/Qwen-Image-Edit-2509

# Model API Base URL
# Description: API endpoint to which all model requests are sent
MODEL_API_BASE_URL=https://api.siliconflow.cn/v1