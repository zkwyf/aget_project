# ============================================
# 使用说明：
# 1. 将此文件复制为 .env
# 2. 填写 OPENAI_API_KEY 和 LANGSMITH_API_KEY
# 3. 填写 HOST_IP
# 4. 可选：填写 TAVILY_SEARCH_KEY 以启用搜索功能
# 5. 根据需要调整功能开关（USE_PPT/USE_EXCEL）
# 6. 保存文件并启动应用程序
# ============================================

# ============================================
# API 密钥配置 - 项目运行所需的认证信息
# ============================================
# SiliconFlow API 密钥（必填）
# 用途：用于访问 SiliconFlow 的 AI 模型服务
# 免费额度获取地址：https://cloud.siliconflow.cn/i/FVis58aF
# 注意：注册后可在控制台中查看 API 密钥
OPENAI_API_KEY=

# LangSmith API 密钥（必填）
# 用途：用于 LangChain 的追踪和监控功能
# 免费注册地址：https://www.langsmith.com/
# 注意：注册后可在设置页面生成 API 密钥
LANGSMITH_API_KEY=

# LangChain 项目名称
# 用途：在 LangSmith 中组织和分类追踪数据
# 说明：所有追踪记录将归类到此项目下，便于管理多个应用程序
LANGCHAIN_PROJECT="all_agent"

# 启用 LangChain 追踪（版本 2）
# 用途：自动追踪 LangChain 应用程序中的所有 LLM 调用和链式执行
# 说明：设置为 true 时，所有 LangChain 操作将被发送到 LangSmith 平台
# 提示：调试时设为 true，生产环境可关闭以减少开销
LANGCHAIN_TRACING_V2=true

# Tavily 搜索 API 密钥（可选）
# 用途：若设置，则启用互联网搜索功能
# 免费注册地址：https://tavily.com/
# 注意：若不设置，互联网搜索功能将禁用，仅使用本地知识库
TAVILY_SEARCH_KEY=

# ============================================
# 服务器网络配置
# ============================================
# 主机 IP 地址 - 服务器绑定的网络接口 IP（必填）
# 用途：
# 1. Agent 创建文件后，MINIO 会生成以 HOST_IP 开头的下载链接供用户下载文件
# 2. 前端程序通过 HOST_IP 路径访问后端程序
# 注意：需要外部可访问的 IP 地址或域名。若无公网接口，请填写本地内网 IP。请勿填写 localhost 或 127.0.0.1
HOST_IP =

# MinIO 对象存储服务端口 - 用于文件存储和访问
MINIO_PORT = 9900

# MinIO 控制台端口 - 用于访问 MinIO 管理界面
MINIO_CONSOLE_PORT = 9901

# MinIO 访问密钥 - API 认证的用户名
MINIO_ACCESS_KEY=minioadmin

# MinIO 密钥 - API 认证的密码
MINIO_SECRET_KEY=minioadmin

# Agent 前端界面端口 - Web 用户界面访问端口
AGENT_UI_PORT=3000

# Agent 后端服务端口 - API 服务访问端口
AGENT_SERVER_PORT=8000

# ============================================
# 应用功能配置 - 控制项目各项功能的开关
# ============================================
# 允许后台任务中的阻塞循环
# 说明：保持此固定值以实现隔离循环，避免任务干扰
# 选项：true/false
BG_JOB_ISOLATED_LOOPS=true

# 启用 PowerPoint 创建功能
# 说明：设为 true 时，AI 可以创建和编辑 PPT 文档
# 选项：true/false
USE_PPT=true

# 启用 Excel 创建功能
# 说明：设为 true 时，AI 可以创建和编辑 Excel 电子表格
# 选项：true/false
USE_EXCEL=true

# ============================================
# 模型配置 - AI 模型选择与参数设置
# ============================================
# 基础大语言模型（LLM）
# 说明：用于文本生成和对话的主要模型
BASE_LLM=Qwen/Qwen3.5-122B-A10B

# 基础视觉语言模型（VLM）
# 说明：用于图像理解和多模态任务
BASE_VLM=Qwen/Qwen3-VL-30B-A3B-Instruct

# 图像生成模型
# 说明：根据文本描述生成图像
IMAGE_MODEL=Qwen/Qwen-Image

# 图像编辑模型
# 说明：修改和编辑现有图像
EDIT_IMAGE_MODEL=Qwen/Qwen-Image-Edit-2509

# 模型 API 基础地址
# 说明：所有模型请求发送到的 API 端点
MODEL_API_BASE_URL=https://api.siliconflow.cn/v1